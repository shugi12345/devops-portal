# SSO Configuration
# When SSO_REQUIRED=true the server rejects requests that lack SSO proxy headers
# In production (k8s) this comes from a ConfigMap; keep false for local dev
SSO_REQUIRED=false

# URL to redirect users to when not authenticated (only used client-side)
SSO_URL=

# Groups allowed to access the portal at all (pipe-separated; leave empty to allow everyone).
# Supports LDAP-style DNs since those contain commas internally.
# Example: ALLOWED_GROUPS=cn=Engineering,ou=Groups,dc=example,dc=com|cn=Ops,ou=Groups,dc=example,dc=com
ALLOWED_GROUPS=

# Groups that receive admin access to the portal (pipe-separated, same syntax as ALLOWED_GROUPS).
# Example: ADMIN_GROUP=cn=Admins,ou=Groups,dc=example,dc=com|cn=Ops,ou=Groups,dc=example,dc=com
ADMIN_GROUP=portal-admins

# Artifactory Configuration
# All three vars are required — the server uses jf CLI for all operations (no mock fallback)
# In production (k8s) these come from a ConfigMap / Secret
ARTIFACTORY_URL=https://artifactory.example.com
ARTIFACTORY_REPO=my-local-repo
ARTIFACTORY_TOKEN=

# Chat / AI Assistant Configuration
# Any OpenAI-compatible API (Groq, Ollama, OpenRouter, RAGFlow, etc.)
# CHAT_API_URL: base URL — /chat/completions is appended automatically
#   Groq:    https://api.groq.com/openai/v1
#   Ollama:  http://localhost:11434/v1
#   RAGFlow: https://ragflow.example.com/api/v1/openai/<chat-id>
# CHAT_MODEL: defaults to gpt-4o-mini if omitted
CHAT_API_URL=
CHAT_API_KEY=
CHAT_MODEL=llama-3.1-8b-instant
# Set to true to use a built-in mock response instead of a real API (useful for dev without credentials)
CHAT_MOCK=false
